# ─── Application ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Origin of the React frontend (no trailing slash)
CORS_ORIGIN=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Matches the docker-compose.yml defaults below
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/progressconsulting?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret in production:  openssl rand -base64 64
JWT_SECRET=change-this-to-a-long-random-secret-before-deploying
JWT_EXPIRES_IN=24h

# ─── Admin Seed ───────────────────────────────────────────────────────────────
# Used only by:  npm run db:seed
# Change these before running the seed in any shared environment.
ADMIN_SEED_EMAIL=admin@progressconsulting.be
ADMIN_SEED_PASSWORD=ChangeMe_2024!
ADMIN_SEED_NAME=Admin
