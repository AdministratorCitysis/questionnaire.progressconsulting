        "id": "timing-like",
        "description": "Le résultat numérique libre peut rester facultatif."
      }
    ]
  },
  "scoring": {
    "rules": [
      {
        "id": "rule-1",
        "kind": "sum_by_group",
        "source": "section:s1",
        "target": "groups",
        "enabled": true
      },
      {
        "id": "rule-2",
        "kind": "conditional_option_value_by_group",
        "source": "question:q2",
        "mappingByGroup": {
          "g1": [
            1,
            2,
            3,
            4
          ],
          "g2": [
            4,
            3,
            2,
            1
          ]
        },
        "enabled": true
      },
      {
        "id": "rule-3",
        "kind": "ranking_points_by_position",
        "source": "section:s2",
        "pointsByRank": [
          14,
          12,
          10,
          8,
          6,
          4,
          2
        ],
        "enabled": true
      },
      {
        "id": "rule-4",
        "kind": "composed_sum",
        "inputs": [
          "rule-1",
          "rule-3"
        ],
        "target": "groups",
        "enabled": true
      },
      {
        "id": "rule-5",
        "kind": "free_numeric_sum",
        "source": "section:s3",
        "target": "global_total",
        "enabled": true
      }
    ]
  },
  "result": {
    "displayMode": "bar_by_group",
    "thresholds": [
      {
        "maxValue": 30,
        "message": "Niveau 1"
      },
      {
        "maxValue": 60,
        "message": "Niveau 2"
      },
      {
        "maxValue": 90,
        "message": "Niveau 3"
      }
    ],
